# ============================
# MIRAI.MAMORU 環境変数
# ============================

# Anthropic API キー
# https://console.anthropic.com/ で取得
OPENAI_API_KEY=sk-proj-...

# バックエンドポート (デフォルト: 3001)
PORT=3001

# ============================
# モバイルアプリ設定
# ============================

# バックエンド API URL
# シミュレーター: http://localhost:3001
# 実機(同じWi-Fi): http://<PCのIPアドレス>:3001
EXPO_PUBLIC_API_URL=http://localhost:3001
